{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/sw.js", "dest": "/public/sw.js", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" } },
    { "src": "/", "dest": "/public/index.html", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" } },
    { "src": "/((?!api/).*)", "dest": "/public/$1" }
  ]
}
